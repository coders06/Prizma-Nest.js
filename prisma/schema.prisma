generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  age   Int
  email String @unique
}

model Product {
  id    Int    @id @default(autoincrement())
  name  String
  price Float
}
